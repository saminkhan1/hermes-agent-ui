{
  "name": "agent-ui",
  "version": "1.0.0",
  "description": "Desktop pet overlay for local Hermes sessions",
  "productName": "agent-UI",
  "main": "out/main/index.js",
  "bin": {
    "agent-ui": "bin/agent-ui.js"
  },
  "files": [
    "bin",
    "out",
    "assets",
    "src",
    "README.md",
    "electron.vite.config.mjs"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "bundle:hermes": "node scripts/bundle-hermes-runtime.js",
    "dist:mac": "npm run bundle:hermes && npm run build && electron-builder --mac dir zip --publish never",
    "start": "electron-vite preview",
    "test": "node --test test/*.test.js",
    "prepare": "electron-vite build"
  },
  "keywords": [
    "electron",
    "desktop-pet",
    "hermes"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "electron": "^41.5.0",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "get-windows": "^9.3.0"
  },
  "overrides": {
    "get-windows": {
      "@mapbox/node-pre-gyp": "^2.0.3",
      "node-gyp": "^12.3.0"
    }
  },
  "build": {
    "appId": "ai.agent-ui.desktop",
    "artifactName": "agent-UI-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "out/**",
      "assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/hermes-runtime",
        "to": "hermes-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "agent-UI uses the microphone to capture voice input for prompts."
      },
      "target": [
        "dir",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    }
  }
}
